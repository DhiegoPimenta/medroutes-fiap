# Chave da API da Anthropic (Claude). Nunca faça commit da chave real.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo Claude utilizado para geração de instruções, relatórios e Q&A
ANTHROPIC_MODEL=claude-sonnet-4-6

# User-Agent exigido pelo Nominatim (OpenStreetMap) para geocodificação
NOMINATIM_USER_AGENT=medroutes-fiap-tech-challenge
