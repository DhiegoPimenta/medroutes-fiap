# Chave da API da Anthropic (Claude). Nunca commitar a chave real.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo Claude utilizado para geracao de instrucoes, relatorios e Q&A
ANTHROPIC_MODEL=claude-sonnet-4-6

# User-Agent exigido pelo Nominatim (OpenStreetMap) para geocodificacao
NOMINATIM_USER_AGENT=medroutes-fiap-tech-challenge
